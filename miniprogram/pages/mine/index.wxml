<view class="page mine-page">
  <view class="profile-card card" bindtap="switchRole">
    <view class="avatar-icon">人</view>
    <view class="profile-main">
      <view class="profile-name">{{userName}}</view>
      <view class="profile-store">{{storeName}}</view>
      <view class="profile-role">{{roleLabel}} · 点击切换角色</view>
    </view>
  </view>

  <block wx:for="{{sections}}" wx:key="index" wx:for-item="section">
    <view class="menu-card card">
      <block wx:for="{{section.items}}" wx:key="name" wx:for-item="menu">
        <view class="menu-row" data-name="{{menu.name}}" bindtap="onTapMenu">
          <view class="menu-left">
            <view class="menu-icon" style="background: {{menu.iconBg}}; color: {{menu.iconColor}};">{{menu.icon}}</view>
            <view class="menu-name">{{menu.name}}</view>
          </view>
          <view class="menu-right">
            <text wx:if="{{menu.value}}" class="menu-value">{{menu.value}}</text>
            <text class="menu-arrow">›</text>
          </view>
        </view>
      </block>
    </view>
  </block>

  <bottom-nav current="mine"></bottom-nav>
</view>
