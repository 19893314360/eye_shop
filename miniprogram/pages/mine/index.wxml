<view class="page">
  <view class="profile card">
    <view class="avatar">徐</view>
    <view class="profile-main">
      <view class="name">{{userName}}</view>
      <view class="desc">{{storeName}}</view>
      <view class="desc">{{roleLabel}}端</view>
      <view class="desc desc-tip">{{loading ? '正在同步登录态...' : ''}}</view>
    </view>
    <button size="mini" class="role-btn" bindtap="switchRole">切换角色</button>
  </view>

  <view class="menu card">
    <block wx:for="{{menu}}" wx:key="name">
      <view class="menu-item" data-name="{{item.name}}" bindtap="onTapMenu">
        <view class="menu-name">{{item.name}}</view>
        <view class="menu-value">{{item.value || ''}}</view>
      </view>
    </block>
  </view>

  <bottom-nav current="mine"></bottom-nav>
</view>
