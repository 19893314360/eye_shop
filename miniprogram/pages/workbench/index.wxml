<view class="page workbench-page">
  <block wx:for="{{sections}}" wx:key="title" wx:for-item="section">
    <view class="section-panel card">
      <view class="section-header">
        <view class="section-marker"></view>
        <view class="section-name">{{section.title}}</view>
      </view>
      <view class="module-grid">
        <block wx:for="{{section.items}}" wx:key="name" wx:for-item="module">
          <view class="module-item" data-name="{{module.name}}" bindtap="onTapModule">
            <view class="module-icon" style="background: {{module.iconBg}}; color: {{module.iconColor}};">{{module.icon}}</view>
            <view wx:if="{{module.badge}}" class="module-badge">{{module.badge}}</view>
            <view class="module-text">{{module.name}}</view>
          </view>
        </block>
      </view>
    </view>
  </block>

  <block wx:for="{{quickActions}}" wx:key="name">
    <view class="quick-row card" data-name="{{item.name}}" bindtap="onTapQuick">
      <view class="quick-title">{{item.name}}</view>
      <view class="quick-placeholder">{{item.placeholder}}</view>
      <view class="quick-tail">{{item.mode === 'scan' ? '▣' : '›'}}</view>
    </view>
  </block>

  <bottom-nav current="workbench"></bottom-nav>
</view>
