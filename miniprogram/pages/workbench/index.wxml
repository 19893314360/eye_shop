<view class="page">
  <view class="role-bar card">
    <view class="section-title">{{roleLabel}}常用功能</view>
    <view class="hint-text">
      {{loading ? '正在同步登录态...' : '快速查单、售后追溯、库存查询入口会放在这里。'}}
    </view>
  </view>

  <view class="search-row card" data-name="快速查单" bindtap="onTapQuick">
    <view class="search-title">快速查单</view>
    <view class="search-placeholder">请输入完整单号或扫码</view>
  </view>
  <view class="search-row card" data-name="售后追溯" bindtap="onTapQuick">
    <view class="search-title">售后追溯</view>
    <view class="search-placeholder">单号、卡号、手机号或扫码</view>
  </view>
  <view class="search-row card" data-name="库存查询" bindtap="onTapQuick">
    <view class="search-title">库存查询</view>
    <view class="search-placeholder">商品名称搜索或点击查找</view>
  </view>

  <block wx:for="{{sections}}" wx:key="title" wx:for-item="section">
    <view class="section card">
      <view class="section-title">{{section.title}}</view>
      <view class="module-grid">
        <block wx:for="{{section.items}}" wx:key="name" wx:for-item="module">
          <view class="module-item" data-name="{{module.name}}" bindtap="onTapModule">
            <view class="module-icon">{{module.name.slice(0, 1)}}</view>
            <view class="module-text">{{module.name}}</view>
            <view wx:if="{{module.badge}}" class="module-badge">{{module.badge}}</view>
          </view>
        </block>
      </view>
    </view>
  </block>

  <bottom-nav current="workbench"></bottom-nav>
</view>
