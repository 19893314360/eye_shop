<view class="page">
  <view class="hero card">
    <view class="hero-top">
      <view>
        <view class="store-name">{{storeName}}</view>
        <view class="store-role">{{roleLabel}}端</view>
      </view>
      <button class="switch-btn" size="mini" bindtap="goEntry">切换角色</button>
    </view>
    <view class="hero-tip">
      {{loading ? '正在同步登录态...' : '公告：点击右上角可切换角色，当前是业务骨架演示环境。'}}
    </view>
  </view>

  <view class="metric-grid">
    <block wx:for="{{metrics}}" wx:key="label">
      <view class="metric-card card">
        <view class="metric-label">{{item.label}}</view>
        <view class="metric-value">{{item.value}}</view>
        <view class="metric-today">{{item.today}}</view>
      </view>
    </block>
  </view>

  <block wx:for="{{sections}}" wx:key="title" wx:for-item="section">
    <view class="section card">
      <view class="section-title">{{section.title}}</view>
      <view class="module-grid">
        <block wx:for="{{section.items}}" wx:key="name" wx:for-item="module">
          <view
            class="module-item"
            data-section="{{section.title}}"
            data-name="{{module.name}}"
            bindtap="onTapModule"
          >
            <view class="module-icon">{{module.name.slice(0, 1)}}</view>
            <view class="module-text">{{module.name}}</view>
            <view wx:if="{{module.badge}}" class="module-badge">{{module.badge}}</view>
          </view>
        </block>
      </view>
    </view>
  </block>

  <bottom-nav current="home"></bottom-nav>
</view>
