<view class="page">
  <view class="card">
    <view class="tabs">
      <block wx:for="{{tabOptions}}" wx:key="key">
        <view class="tab-item {{currentTab === item.key ? 'tab-item--active' : ''}}" data-tab="{{item.key}}" bindtap="onTabChange">
          {{item.label}}
        </view>
      </block>
    </view>
  </view>

  <!-- 报销记录 -->
  <view wx:if="{{currentTab === 'list'}}" class="card">
    <view class="section-title">报销记录</view>
    <view wx:if="{{!claims.length}}" class="hint-text">暂无报销记录</view>
    <block wx:for="{{claims}}" wx:key="id">
      <view class="claim-item">
        <view class="claim-top">
          <view class="claim-title">{{item.title}}</view>
          <view class="claim-status status-{{item.status}}">{{item.statusLabel}}</view>
        </view>
        <view class="claim-meta">{{item.category}} · ￥{{item.amount}} · {{item.applicant}}</view>
        <view class="claim-meta">{{item.createdText}}</view>
        <view wx:if="{{item.description}}" class="claim-meta">说明：{{item.description}}</view>
        <view wx:if="{{item.status === 'pending' && role === 'manager'}}" class="claim-actions">
          <button size="mini" class="primary-btn" data-id="{{item.id}}" data-status="approved" bindtap="approveClaim">通过</button>
          <button size="mini" class="danger-btn" data-id="{{item.id}}" data-status="rejected" bindtap="approveClaim">驳回</button>
        </view>
      </view>
    </block>
  </view>

  <!-- 申请报销 -->
  <view wx:if="{{currentTab === 'apply'}}" class="card">
    <view class="section-title">申请报销</view>
    <view class="field">
      <view class="field-label">报销标题 *</view>
      <input class="field-input" placeholder="如：客户拜访交通费" value="{{form.title}}" data-field="title" bindinput="onFormInput" />
    </view>
    <view class="field">
      <view class="field-label">费用类型</view>
      <picker mode="selector" range="{{categoryOptions}}" value="{{form.categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker-value">{{categoryOptions[form.categoryIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <view class="field-label">报销金额 *</view>
      <input class="field-input" type="digit" placeholder="请输入金额" value="{{form.amount}}" data-field="amount" bindinput="onFormInput" />
    </view>
    <view class="field">
      <view class="field-label">费用说明</view>
      <textarea class="field-textarea" maxlength="120" placeholder="请简要说明费用用途" value="{{form.description}}" data-field="description" bindinput="onFormInput" />
    </view>
    <button class="primary-btn" loading="{{submitting}}" bindtap="submitClaim">提交申请</button>
  </view>
</view>
