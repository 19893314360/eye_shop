<view class="page entry-page">
  <view class="banner card">
    <view class="title">角色切换</view>
    <view class="desc">当前身份：{{currentRoleLabel}} {{userName ? '（' + userName + '）' : ''}}</view>
    <view class="hint">{{loading ? '正在加载...' : '切换角色后将重新登录并以新身份进入系统。'}}</view>
  </view>

  <view class="list-title">选择要切换的身份</view>
  <block wx:for="{{roleOptions}}" wx:key="key">
    <view class="role-card card {{loading ? 'role-card--disabled' : ''}} {{item.key === currentRole ? 'role-card--current' : ''}}" data-role="{{item.key}}" bindtap="chooseRole">
      <view class="role-card__header">
        <view class="role-name">{{item.label}}</view>
        <view class="role-tag {{item.key === currentRole ? 'role-tag--active' : ''}}">
          {{item.key === currentRole ? '当前' : '切换'}}
        </view>
      </view>
      <view class="role-desc">{{item.desc}}</view>
    </view>
  </block>

  <view class="back-row">
    <button class="back-btn" bindtap="goBack">返回上一页</button>
  </view>
</view>
