<view class="page entry-page">
  <view class="banner card">
    <view class="title">眼镜门店小程序</view>
    <view class="desc">当前身份：{{currentRoleLabel}}</view>
    <view class="hint">{{loading ? '正在初始化登录上下文...' : '先确定演示角色，后续再接入真实登录与组织权限。'}}</view>
  </view>

  <view class="list-title">选择要进入的端</view>
  <block wx:for="{{roleOptions}}" wx:key="key">
    <view class="role-card card {{loading ? 'role-card--disabled' : ''}}" data-role="{{item.key}}" bindtap="chooseRole">
      <view class="role-card__header">
        <view class="role-name">{{item.label}}</view>
        <view class="role-tag {{item.key === currentRole ? 'role-tag--active' : ''}}">
          {{item.key === currentRole ? '当前' : '切换'}}
        </view>
      </view>
      <view class="role-desc">{{item.desc}}</view>
    </view>
  </block>
</view>
