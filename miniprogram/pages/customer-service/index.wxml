<view class="page">
  <view class="chat-container">
    <scroll-view
      class="message-list"
      scroll-y
      scroll-into-view="{{scrollToView}}"
      scroll-with-animation
    >
      <block wx:for="{{messages}}" wx:key="id">
        <view class="message-item {{item.role === 'user' ? 'message-right' : 'message-left'}}" id="msg-{{item.id}}">
          <view class="avatar {{item.role === 'user' ? 'avatar-user' : 'avatar-service'}}">
            {{item.role === 'user' ? '我' : '客'}}
          </view>
          <view class="message-bubble {{item.role === 'user' ? 'bubble-user' : 'bubble-service'}}">
            <view class="bubble-content">{{item.content}}</view>
            <view class="bubble-time">{{item.timeText}}</view>
          </view>
        </view>
      </block>

      <view wx:if="{{typing}}" class="message-item message-left">
        <view class="avatar avatar-service">客</view>
        <view class="message-bubble bubble-service">
          <view class="typing-indicator">
            <view class="typing-dot"></view>
            <view class="typing-dot"></view>
            <view class="typing-dot"></view>
          </view>
        </view>
      </view>
    </scroll-view>

    <view class="input-bar">
      <input
        class="input-field"
        placeholder="请输入您的问题..."
        value="{{inputValue}}"
        bindinput="onInput"
        bindconfirm="sendMessage"
        confirm-type="send"
        disabled="{{sending}}"
      />
      <button class="send-btn" bindtap="sendMessage" disabled="{{!inputValue.trim() || sending}}">
        {{sending ? '发送中' : '发送'}}
      </button>
    </view>
  </view>

  <view class="quick-replies">
    <view class="quick-title">常见问题</view>
    <view class="quick-list">
      <block wx:for="{{quickReplies}}" wx:key="*this">
        <view class="quick-item" data-text="{{item}}" bindtap="sendQuickReply">{{item}}</view>
      </block>
    </view>
  </view>
</view>
