<view class="page">
  <view wx:if="{{loading}}" class="hint-text">加载中...</view>

  <block wx:if="{{!loading}}">
    <!-- 门店信息 -->
    <view class="card">
      <view class="section-title">{{storeName}}</view>
      <view class="info-row">
        <view class="info-label">门店电话</view>
        <view class="info-value phone-value" bindtap="callStore">{{storePhone}}</view>
      </view>
      <view class="info-row">
        <view class="info-label">门店地址</view>
        <view class="info-value link-value" bindtap="openLocation">{{storeAddress}}</view>
      </view>
      <view class="info-row">
        <view class="info-label">营业时间</view>
        <view class="info-value">{{workTime}}</view>
      </view>
    </view>

    <!-- 在线客服 -->
    <view class="card">
      <view class="section-title">在线客服</view>
      <view class="info-row">
        <view class="info-label">服务时间</view>
        <view class="info-value">{{onlineTime}}</view>
      </view>
      <view class="action-row">
        <button class="action-btn primary-btn" bindtap="callStore">电话咨询</button>
        <button class="action-btn secondary-btn" bindtap="copyPhone">复制电话</button>
      </view>
    </view>

    <!-- 常见问题快捷入口 -->
    <view class="card">
      <view class="section-title">常见问题</view>
      <block wx:for="{{faqItems}}" wx:key="question">
        <view class="faq-item" data-route="{{item.route}}" bindtap="goFaqItem">
          <view class="faq-question">{{item.question}}</view>
          <view class="faq-arrow">></view>
        </view>
      </block>
      <view class="faq-more" bindtap="goFaq">查看全部常见问题 ></view>
    </view>
  </block>
</view>
