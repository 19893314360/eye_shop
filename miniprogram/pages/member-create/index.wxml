<view class="page">
  <view class="card">
    <view class="section-title">会员信息</view>

    <view class="field">
      <view class="field-label">姓名 *</view>
      <input
        class="field-input"
        placeholder="请输入会员姓名"
        value="{{form.name}}"
        data-field="name"
        bindinput="onInput"
      />
    </view>

    <view class="field">
      <view class="field-label">手机号 *</view>
      <input
        class="field-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{form.mobile}}"
        data-field="mobile"
        bindinput="onInput"
      />
    </view>

    <view class="field">
      <view class="field-label">性别</view>
      <picker mode="selector" range="{{genderOptions}}" range-key="label" value="{{genderIndex}}" bindchange="onGenderChange">
        <view class="picker-value">{{genderOptions[genderIndex].label}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="field-label">生日</view>
      <input
        class="field-input"
        placeholder="示例：1995-06-18"
        value="{{form.birthday}}"
        data-field="birthday"
        bindinput="onInput"
      />
    </view>

    <view class="field">
      <view class="field-label">备注</view>
      <textarea
        class="field-textarea"
        maxlength="120"
        placeholder="可填写过敏史、偏好等信息"
        value="{{form.note}}"
        data-field="note"
        bindinput="onInput"
      />
    </view>

    <button class="primary-btn" loading="{{submitting}}" bindtap="submit">提交会员</button>
    <button class="secondary-btn" bindtap="goOrderCreate">下一步：去开单</button>
  </view>

  <view class="card list-card">
    <view class="section-title">最近会员</view>
    <view wx:if="{{loadingList}}" class="hint-text">加载中...</view>
    <view wx:if="{{!loadingList && !recentMembers.length}}" class="hint-text">暂无数据</view>
    <block wx:for="{{recentMembers}}" wx:key="id">
      <view class="member-item">
        <view class="member-main">
          <view class="member-name">{{item.name}}</view>
          <view class="member-mobile">{{item.mobile}}</view>
        </view>
        <view class="member-meta">{{item.gender === 'male' ? '男' : (item.gender === 'female' ? '女' : '未知')}}</view>
      </view>
    </block>
  </view>
</view>
