<view class="page">
  <view class="card">
    <view class="section-title">会员筛选</view>
    <view class="search-row">
      <input
        class="search-input"
        placeholder="输入会员姓名或手机号"
        value="{{keyword}}"
        bindinput="onKeywordInput"
        bindconfirm="onSearch"
        confirm-type="search"
      />
      <button class="search-btn" size="mini" bindtap="onSearch">搜索</button>
    </view>
    <button class="secondary-btn" bindtap="goCreate">+ 新增会员</button>
  </view>

  <view class="card list-card">
    <view class="section-title">会员列表</view>
    <view wx:if="{{loading}}" class="hint-text">加载中...</view>
    <view wx:if="{{!loading && !list.length}}" class="hint-text">暂无会员</view>
    <block wx:for="{{list}}" wx:key="id">
      <view class="item">
        <view class="item-top">
          <view>
            <view class="name">{{item.name}}（{{item.gender === 'male' ? '男' : (item.gender === 'female' ? '女' : '未知')}}）</view>
            <view class="meta">{{item.mobile}}</view>
          </view>
          <view class="meta">{{item.createdText}}</view>
        </view>
        <view class="actions">
          <button size="mini" class="action-btn" data-id="{{item.id}}" bindtap="goOrderCreate">去开单</button>
          <button size="mini" class="action-btn" data-id="{{item.id}}" bindtap="goVisionProfile">视力档案</button>
          <button size="mini" class="action-btn" data-name="{{item.name}}" data-mobile="{{item.mobile}}" bindtap="goAppointment">预约</button>
          <button size="mini" class="action-btn" bindtap="goAfterSale">售后</button>
        </view>
      </view>
    </block>
  </view>
</view>
