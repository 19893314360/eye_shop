<view class="page">
  <view class="card">
    <view class="section-title">开单信息</view>

    <view class="field">
      <view class="field-label">选择会员 *</view>
      <block wx:if="{{memberList.length}}">
        <picker mode="selector" range="{{memberList}}" range-key="name" value="{{memberIndex}}" bindchange="onMemberChange">
          <view class="picker-value">
            {{memberList[memberIndex].name}}（{{memberList[memberIndex].mobile}}）
          </view>
        </picker>
      </block>
      <view wx:else class="hint-text">暂无会员，请先新增会员</view>
    </view>

    <view class="field">
      <view class="field-label">开单类型</view>
      <picker mode="selector" range="{{orderTypeOptions}}" range-key="label" value="{{orderTypeIndex}}" bindchange="onOrderTypeChange">
        <view class="picker-value">{{orderTypeOptions[orderTypeIndex].label}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="field-label">商品名称 *</view>
      <input
        class="field-input"
        placeholder="如：超薄镜片 1.67"
        value="{{form.itemName}}"
        data-field="itemName"
        bindinput="onInput"
      />
    </view>

    <view class="row">
      <view class="field half">
        <view class="field-label">数量 *</view>
        <input
          class="field-input"
          type="number"
          value="{{form.quantity}}"
          data-field="quantity"
          bindinput="onInput"
        />
      </view>
      <view class="field half">
        <view class="field-label">单价（元）*</view>
        <input
          class="field-input"
          type="digit"
          value="{{form.unitPrice}}"
          data-field="unitPrice"
          bindinput="onInput"
        />
      </view>
    </view>

    <view class="amount-box">
      <view class="amount-label">应收合计</view>
      <view class="amount-value">￥{{amountPreview}}</view>
    </view>

    <view class="field">
      <view class="field-label">备注</view>
      <textarea
        class="field-textarea"
        maxlength="120"
        placeholder="如有加工要求可填写"
        value="{{form.note}}"
        data-field="note"
        bindinput="onInput"
      />
    </view>

    <button class="primary-btn" loading="{{submitting}}" bindtap="submit">提交开单</button>
    <view class="action-row">
      <button class="secondary-btn action" bindtap="goMemberCreate">新增会员</button>
      <button class="secondary-btn action" bindtap="goPayment">去收款</button>
    </view>
    <view wx:if="{{createdOrderNo}}" class="hint-text">最近开单：{{createdOrderNo}}</view>
  </view>
</view>
