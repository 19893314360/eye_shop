<view class="page">
  <view class="card">
    <view class="section-title">提交预约</view>

    <view class="field">
      <view class="field-label">预约人 *</view>
      <input
        class="field-input"
        placeholder="请输入姓名"
        value="{{form.customerName}}"
        data-field="customerName"
        bindinput="onInput"
      />
    </view>

    <view class="field">
      <view class="field-label">手机号 *</view>
      <input
        class="field-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{form.mobile}}"
        data-field="mobile"
        bindinput="onInput"
      />
    </view>

    <view class="field">
      <view class="field-label">预约服务</view>
      <picker mode="selector" range="{{serviceOptions}}" range-key="label" value="{{serviceIndex}}" bindchange="onServiceChange">
        <view class="picker-value">{{serviceOptions[serviceIndex].label}}</view>
      </picker>
    </view>

    <view class="row">
      <view class="field half">
        <view class="field-label">日期</view>
        <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
          <view class="picker-value">{{form.date}}</view>
        </picker>
      </view>
      <view class="field half">
        <view class="field-label">时间</view>
        <picker mode="time" value="{{form.time}}" bindchange="onTimeChange">
          <view class="picker-value">{{form.time}}</view>
        </picker>
      </view>
    </view>

    <view class="field">
      <view class="field-label">备注</view>
      <textarea
        class="field-textarea"
        maxlength="120"
        placeholder="可填写预约说明"
        value="{{form.note}}"
        data-field="note"
        bindinput="onInput"
      />
    </view>

    <button class="primary-btn" loading="{{saving}}" bindtap="submit">提交预约</button>
  </view>

  <view class="card list-card">
    <view class="section-title">预约记录</view>
    <view wx:if="{{loading}}" class="hint-text">加载中...</view>
    <view wx:if="{{!loading && !list.length}}" class="hint-text">暂无预约记录</view>
    <block wx:for="{{list}}" wx:key="id">
      <view class="item">
        <view class="item-top">
          <view class="name">{{item.customerName}} · {{item.mobile}}</view>
          <view class="status {{item.status === 'done' ? 'status--done' : 'status--pending'}}">
            {{item.status === 'done' ? '已到店' : '待到店'}}
          </view>
        </view>
        <view class="meta">
          {{item.serviceType === 'recheck' ? '复查预约' : (item.serviceType === 'training' ? '视训预约' : '验光预约')}} · {{item.date}} {{item.time}}
        </view>
        <view class="meta">{{item.note || '无备注'}}</view>
        <button
          wx:if="{{role !== 'customer' && item.status !== 'done'}}"
          size="mini"
          class="secondary-btn"
          loading="{{arrivingId === item.id}}"
          disabled="{{arrivingId === item.id}}"
          data-id="{{item.id}}"
          bindtap="markArrived"
        >
          标记到店
        </button>
      </view>
    </block>
  </view>
</view>
