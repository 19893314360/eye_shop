<view class="page">
  <view class="card">
    <view class="section-title">采购记录</view>
    <view class="tabs">
      <block wx:for="{{tabOptions}}" wx:key="key">
        <view
          class="tab-item {{currentTab === item.key ? 'tab-item--active' : ''}}"
          data-tab="{{item.key}}"
          bindtap="onTabChange"
        >
          {{item.label}}
        </view>
      </block>
    </view>
  </view>

  <view class="card form-card">
    <view class="section-title">新增记录</view>
    <view class="field">
      <view class="field-label">类型</view>
      <picker mode="selector" range="{{typeOptions}}" range-key="label" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="picker-value">{{typeOptions[typeIndex].label}}</view>
      </picker>
    </view>
    <view class="field">
      <view class="field-label">商品名称 *</view>
      <input class="field-input" value="{{form.itemName}}" data-field="itemName" bindinput="onInput" />
    </view>
    <view class="field">
      <view class="field-label">SKU *</view>
      <input class="field-input" value="{{form.sku}}" data-field="sku" bindinput="onInput" />
    </view>
    <view class="row">
      <view class="field half">
        <view class="field-label">数量 *</view>
        <input class="field-input" type="number" value="{{form.qty}}" data-field="qty" bindinput="onInput" />
      </view>
      <view class="field half">
        <view class="field-label">单价 *</view>
        <input class="field-input" type="digit" value="{{form.unitCost}}" data-field="unitCost" bindinput="onInput" />
      </view>
    </view>
    <view class="field">
      <view class="field-label">供应商 *</view>
      <input class="field-input" value="{{form.supplier}}" data-field="supplier" bindinput="onInput" />
    </view>
    <view class="field">
      <view class="field-label">备注</view>
      <textarea class="field-textarea" maxlength="120" value="{{form.note}}" data-field="note" bindinput="onInput" />
    </view>
    <button class="primary-btn" loading="{{submitting}}" bindtap="submit">提交记录</button>
  </view>

  <view class="card list-card">
    <view class="section-title">记录列表</view>
    <view wx:if="{{loading}}" class="hint-text">加载中...</view>
    <view wx:if="{{!loading && !list.length}}" class="hint-text">暂无记录</view>
    <block wx:for="{{list}}" wx:key="id">
      <view class="item">
        <view class="item-top">
          <view class="name">{{item.itemName}}（{{item.sku}}）</view>
          <view class="type-tag">{{item.typeLabel}}</view>
        </view>
        <view class="meta">数量 {{item.qty}} · 单价 ￥{{item.unitCost}} · 合计 ￥{{item.amountText}}</view>
        <view class="meta">{{item.supplier}} · {{item.operator}} · {{item.createdText}}</view>
        <view wx:if="{{item.note}}" class="meta">备注：{{item.note}}</view>
      </view>
    </block>
  </view>
</view>
